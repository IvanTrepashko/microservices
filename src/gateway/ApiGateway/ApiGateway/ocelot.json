{
  "GlobalConfiguration": {
    "ClusterServiceNames": {
      "AuthenticationService": "http://localhost:5002",
      "ClientService": "http://localhost:5004"
    }
  },
  "Aggregates": [],
  "Routes": [
    {
      "SwaggerKey": "client",
      "DownstreamPathTemplate": "/api/client/profile",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "{service:ClientService}"
        }
      ],
      "UpstreamPathTemplate": "/api/client/profile",
      "UpstreamHttpMethod": [
        "POST",
        "GET"
      ],
      "QoSOptions": {
        "ExceptionsAllowedBeforeBreaking": 3,
        "DurationOfBreak": 10000,
        "TimeoutValue": 5000
      }
    },
    {
      "SwaggerKey": "auth",
      "DownstreamPathTemplate": "/api/auth/login",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "{service:AuthenticationService}"
        }
      ],
      "UpstreamPathTemplate": "/api/auth/login",
      "UpstreamHttpMethod": [
        "POST"
      ],
      "QoSOptions": {
        "ExceptionsAllowedBeforeBreaking": 3,
        "DurationOfBreak": 10000,
        "TimeoutValue": 5000
      }
    },
    {
      "SwaggerKey": "auth",
      "DownstreamPathTemplate": "/api/auth/register",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "{service:AuthenticationService}"
        }
      ],
      "UpstreamPathTemplate": "/api/auth/register",
      "UpstreamHttpMethod": [
        "POST"
      ],
      "QoSOptions": {
        "ExceptionsAllowedBeforeBreaking": 3,
        "DurationOfBreak": 10000,
        "TimeoutValue": 5000
      }
    }
  ],
  "SwaggerEndPoints": [
    {
      "Key": "client",
      "Config": [
        {
          "Name": "Client API",
          "Version": "v1",
          "Url": "http://localhost:5004/swagger/v1/swagger.json"
        }
      ]
    },
    {
      "Key": "auth",
      "Config": [
        {
          "Name": "Auth API",
          "Version": "v1",
          "Url": "http://localhost:5002/swagger/v1/swagger.json"
        }
      ]
    }
  ]
}